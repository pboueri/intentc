}
```

## vite.config.js

```js
import { defineConfig } from 'vite';

export default defineConfig({
  root: '.',
  base: './',
  build: {
    outDir: 'dist',
    target: 'es2022',
    minify: 'terser',
    sourcemap: false,
    rollupOptions: {
      input: 'index.html',
    },
  },
  server: {
    port: 3000,
    open: true,
  },
  test: {
    environment: 'jsdom',
    globals: true,
    include: ['src/**/*.test.js'],
  },
});
```

## Complete Directory Structure

```
zoo-builder/
  index.html
  vite.config.js
  package.json
  src/
    main.js               # Entry point: creates canvas, boots game
    constants.js           # All magic numbers and configuration
    game_loop.js           # requestAnimationFrame loop, fixed timestep
    state.js               # createGameState(), state shape definition
    map.js                 # Tile grid, A* pathfinding, placement validation
    renderer.js            # All canvas drawing, camera, layers, mini-map
    input.js               # Mouse/keyboard event handlers, state machine
    animals.js             # Species data, animal update, breeding, death
    enclosures.js          # Biome defs, degradation, repair, upgrades
    economy.js             # Revenue, costs, demand curve, bankruptcy
    visitors.js            # Visitor AI, pathfinding, satisfaction
    ui.js                  # HUD, sidebar, tooltips, toasts, build ghost
    research.js            # Tech tree, progress, unlock effects
    audio.js               # Web Audio API, music, SFX, volume control
    save_system.js         # localStorage save/load, serialization, slots
    utils.js               # clamp, lerp, distance, random helpers
  src/__tests__/
    animals.test.js
    economy.test.js
    enclosures.test.js
    map.test.js
    visitors.test.js
    save_system.test.js
    game_loop.test.js
  public/
    (static assets if any)
```

