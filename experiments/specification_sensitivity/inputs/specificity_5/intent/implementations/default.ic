export const ANIMAL_SPRITE_SIZE = 32;
export const VISITOR_SPRITE_SIZE = 16;

// --- Animation ---
export const ANIMAL_IDLE_FRAMES = 2;
export const ANIMAL_IDLE_MS = 500;
export const VISITOR_WALK_FRAMES = 4;
export const VISITOR_WALK_MS = 200;

// --- Economy ---
export const STARTING_MONEY = 10000;
export const FOOD_COST_PER_TICK = 0.5;   // multiplied by species foodCost
export const MAINTENANCE_COST_BASE = 0.2;
export const BANKRUPTCY_GRACE_SECONDS = 30;

// --- Animals ---
export const BREED_THRESHOLD = 80;        // happiness >= this to breed
export const BREED_CHANCE_PER_TICK = 0.02; // 2% per tick per eligible pair
export const BREED_COOLDOWN_DEFAULT = 60;  // ticks
export const HUNGER_RATE = 0.3;           // per tick
export const HAPPINESS_LERP = 0.05;       // per tick toward target
export const HEALTH_DECAY_RATE = 0.1;     // per tick when unhappy

// --- Visitors ---
export const VISITOR_SPEED = 1.5;         // tiles per second
export const VISITOR_VIEW_TIME = 3.0;     // seconds
export const MAX_VISITORS = 50;

// --- UI ---
export const HUD_HEIGHT = 40;
export const SIDEBAR_WIDTH = 240;
export const INFO_BAR_HEIGHT = 40;
export const TOOLTIP_MAX_WIDTH = 200;
export const TOAST_DURATION_MS = 3000;

// --- Research ---
export const RESEARCH_BASE_COST = 2000;
export const RESEARCH_COST_MULTIPLIER = 1.5;

// --- Save ---
export const SAVE_VERSION = 1;
export const AUTO_SAVE_INTERVAL_S = 60;
export const MAX_SAVE_SLOTS = 3;

// --- Speeds ---
export const SPEED_OPTIONS = [1, 2, 3];
```

## State Shape (summary)

```js
export function createGameState() {
  return {
    phase: 'menu',           // 'loading' | 'menu' | 'playing' | 'paused' | 'game_over'
    tick: 0,
    timeElapsed: 0,          // real seconds
    speed: 1,                // 1, 2, or 3
    money: STARTING_MONEY,
    admissionPrice: 5,
    animals: [],             // Array<AnimalEntity>
    enclosures: [],          // Array<EnclosureEntity>
    visitors: [],            // Array<VisitorEntity>
    map: null,               // 2D array initialized by map.js
    research: {},            // keyed by node id, { unlocked, progress }
    camera: { x: 0, y: 0 },
    input: { mode: 'idle', hover: null, selected: null },
    ui: { toasts: [], activeTab: 'build' },
    economy: { history: [], bankruptcyTimer: 0, peakAnimals: 0, totalVisitors: 0, totalRevenue: 0 },
    audio: { musicVolume: 0.5, sfxVolume: 0.7 },
    autoSaveTimer: 0,
  };
}
```

## Testing Strategy

Unit tests cover pure logic modules:

- **animals.test.js** — Happiness formula, hunger increase, breeding eligibility, death condition
- **economy.test.js** — Demand curve output at various price/species combos, bankruptcy timer, net income calculation
- **enclosures.test.js** — Degradation rate, repair cost formula, upgrade capacity increases
- **map.test.js** — A* pathfinding returns valid path, `isValidPlacement` boundary checks
- **visitors.test.js** — State transitions, satisfaction accumulation, spawn rate calculation
- **save_system.test.js** — Serialize/deserialize round-trip, corrupt data handling, version migration
- **game_loop.test.js** — State machine transitions, delta accumulator clamping

Each test file targets the exported functions of its module, injecting a mock state object. No canvas or DOM mocking is needed for logic tests.
