target: game_engine
agent_profile: null
validations:
  - name: engine_architecture
    type: agent_validation
    severity: error
    args:
      rubric: >
        Verify that the game engine implements:
        1. A requestAnimationFrame-based game loop with fixed-timestep physics updates.
        2. A Canvas 2D rendering pipeline with drawing primitives for triangles, squares, circles, and stars.
        3. A camera system that follows the player horizontally and tracks vertical movement.
        4. Keyboard input handling that tracks key-down/key-up state for continuous movement.
        5. Gravity-based physics with velocity, friction, and acceleration.
        6. A collision detection system with both AABB broad-phase and shape-specific narrow-phase checks.
        7. A configurable particle system that can emit triangle, square, or circle shaped particles.
