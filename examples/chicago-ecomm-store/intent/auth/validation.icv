target: auth
agent_profile: null
validations:
  - name: register_endpoint
    type: agent_validation
    severity: error
    args:
      rubric: "POST /api/auth/register must accept email and password, hash the password with bcrypt, create a customer user in the database, and return a JWT token with user info."
  - name: login_endpoint
    type: agent_validation
    severity: error
    args:
      rubric: "POST /api/auth/login must accept email and password, validate credentials against the database, and return a JWT token with user info. Invalid credentials must return 401."
  - name: auth_middleware
    type: agent_validation
    severity: error
    args:
      rubric: "There must be an authMiddleware that verifies JWT tokens from the Authorization header and attaches the decoded user to the request object."
  - name: admin_middleware
    type: agent_validation
    severity: error
    args:
      rubric: "There must be an adminMiddleware that checks the authenticated user has the 'admin' role and returns 403 for non-admin users."
