target: product_catalog
agent_profile: null
validations:
  - name: public_read_endpoints
    type: agent_validation
    severity: error
    args:
      rubric: "GET /api/products must return a list of all products and GET /api/products/:id must return a single product. Both endpoints should be publicly accessible without authentication."
  - name: admin_write_endpoints
    type: agent_validation
    severity: error
    args:
      rubric: "POST /api/products, PUT /api/products/:id, and DELETE /api/products/:id must require admin authentication. These endpoints should create, update, and delete products respectively."
  - name: seed_products
    type: agent_validation
    severity: error
    args:
      rubric: "The seed data must include at least three Chicago-themed products: deep dish pizza, Jeppson's Malort, and a Chicago-style hot dog. Each must have a name, description, price, image URL, and inventory count."
