target: build/agents
version: 1
validations:
  - name: agent-module-exists
    type: agent_validation
    severity: error
    args:
      rubric: |
        Verify that the agent module exists within the output directory's main package
        and contains the core agent types and implementations.

  - name: agent-interface-defined
    type: agent_validation
    severity: error
    args:
      rubric: |
        Verify the agent module defines:
        1. Agent interface with Build, Validate, Difference, Plan, GetName, GetType methods
        2. BuildContext type with all specified fields including ResponseFilePath
        3. DifferencingContext type with fields: OutputDirA, OutputDirB, ProjectIntent, Implementation, ResponseFilePath
        4. CLIAgent base implementation that constructs prompts and reads response files
        5. ClaudeAgent with Claude-specific flags (-p, --output-format stream-json, --dangerously-skip-permissions, --model)
        6. CreateFromProfile factory function
        7. MockAgent for testing (records all calls including Difference, returns configurable responses)
        8. BuildResponse, ValidationResponse, DimensionResult, and DifferencingResponse types
        9. AgentProfile with timeout default of 3600.0 seconds
        10. PromptTemplates, load_default_prompts(), render_prompt(), render_differencing_prompt()

  - name: agent-tests-pass
    type: agent_validation
    severity: error
    args:
      rubric: |
        Run the test suite for the agent module and verify all tests pass with exit code 0.
        Use the implementation's test runner (e.g., pytest for Python, go test for Go).
