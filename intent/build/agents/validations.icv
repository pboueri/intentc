---
target: agent
version: 1
validations:
  - name: agent-module-exists
    type: folder_check
    path: src/agent

  - name: agent-interface-defined
    type: llm_judge
    rubric: |
      Verify the agent module defines:
      1. Agent interface with Build, Validate, GetName, GetType methods
      2. BuildContext type with all specified fields
      3. CLIAgent base implementation
      4. ClaudeAgent that extends CLIAgent with Claude-specific CLI args
      5. CreateFromProfile factory function
      6. MockAgent for testing
    severity: error
    context_files: ["src/agent/**"]

  - name: agent-tests-pass
    type: command_check
    command: cd src && uv run pytest agent/ -v
    exit_code: 0
---
