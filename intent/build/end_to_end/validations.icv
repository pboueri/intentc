target: build/end_to_end
version: 1
validations:
  - name: e2e-tests-pass
    type: agent_validation
    severity: error
    args:
      rubric: |
        Run `python -m pytest src/intentc/build/test_end_to_end.py -v` from
        the repository root. The validation passes if and only if all tests
        exit with code 0 and no failures or errors are reported.
      context_files: ["intentc/build/test_end_to_end.py"]
