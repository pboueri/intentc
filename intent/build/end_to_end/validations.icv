target: build/end_to_end
version: 1
validations:
  - name: e2e-tests-pass
    type: agent_validation
    severity: error
    args:
      rubric: |
        Run the end-to-end test suite for the build pipeline and verify all tests pass
        with exit code 0. Use the implementation's test runner (e.g., pytest for Python,
        go test for Go). Look for the end-to-end test file within the build module of
        the output directory.
