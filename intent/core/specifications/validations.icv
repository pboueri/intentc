target: core/specifications
version: 1
validations:
  - name: core-types-defined
    type: agent_validation
    severity: error
    args:
      rubric: |
        Verify the core modules have been created with the key types and there are no dependencies.

  - name: file-io
    type: agent_validation
    severity: error
    args:
      rubric: |
        Validate the test cases cover reading and writing to disk and that they pass.
