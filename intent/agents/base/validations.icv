---
target: agents/base
version: 1
validations:
  - name: agent-module-exists
    type: folder_check
    path: src/agent

  - name: agent-interface-defined
    type: llm_judge
    rubric: |
      Verify the agent module defines the Agent interface with Build, Validate, GetName, GetType methods and BuildContext type.
    severity: error
    context_files: ["src/agent/**"]

  - name: agent-tests-pass
    type: command_check
    command: cd src && uv run pytest agent/ -v
    exit_code: 0
---
